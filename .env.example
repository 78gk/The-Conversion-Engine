# The Conversion Engine — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git (it is in .gitignore).
#
# Where to get each key:
#   Resend:           https://resend.com/api-keys
#   Africa's Talking: https://account.africastalking.com/apps/sandbox/settings/key
#   HubSpot:          https://app.hubspot.com/developer/{portal-id}/apps/{app-id}/auth
#   Cal.com:          https://app.cal.com/settings/developer/api-keys
#   OpenRouter:       https://openrouter.ai/keys
#   Langfuse:         https://cloud.langfuse.com → Settings → API Keys

# ─────────────────────────────────────────────
# LLM BACKBONE
# ─────────────────────────────────────────────

# OpenRouter API key (supports 100+ models, free tier available)
OPENROUTER_API_KEY=YOUR_OPENROUTER_KEY_HERE

# LiteLLM-compatible model string for agent LLM
# Free options: openrouter/mistralai/mistral-7b-instruct:free
#               openrouter/google/gemma-3-4b-it:free
AGENT_LLM_MODEL=openrouter/mistralai/mistral-7b-instruct:free

# Model for the tau2-bench user simulator
USER_LLM_MODEL=openrouter/mistralai/mistral-7b-instruct:free

# ─────────────────────────────────────────────
# EMAIL — RESEND
# ─────────────────────────────────────────────

# Resend API key (free tier: 100 emails/day, no credit card)
RESEND_API_KEY=re_REPLACE_ME

# Sender address (must be verified in Resend dashboard)
# For sandbox testing, use the Resend test address:
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=Kirubel at Tenacious

# When OUTBOUND_LIVE=false, all emails are logged to stdout only
# When OUTBOUND_LIVE=true, emails are sent via Resend API
OUTBOUND_LIVE=false

# Staff sink for all outbound in sandbox mode (your own email)
STAFF_SINK_EMAIL=REPLACE_WITH_YOUR_EMAIL

# ─────────────────────────────────────────────
# SMS — AFRICA'S TALKING
# ─────────────────────────────────────────────

# Africa's Talking credentials
# Username is "sandbox" for the free sandbox environment
AT_USERNAME=sandbox
AT_API_KEY=REPLACE_ME

# Sender ID (must be registered with Africa's Talking)
# Use "AFRICASTKNG" in sandbox, your approved ID in production
AT_SENDER_ID=AFRICASTKNG

# Set to "true" to use the AT sandbox (free, no real SMS sent)
AT_SANDBOX=true

# ─────────────────────────────────────────────
# CRM — HUBSPOT
# ─────────────────────────────────────────────

# HubSpot private app access token
# Create at: Settings → Integrations → Private Apps → Create
# Scopes required: crm.objects.contacts.write, crm.objects.contacts.read
HUBSPOT_ACCESS_TOKEN=pat-eu1-REPLACE_ME

# Your HubSpot portal ID (visible in the URL: app.hubspot.com/{portal-id}/)
HUBSPOT_PORTAL_ID=REPLACE_ME

# Default deal owner ID (your HubSpot user ID)
HUBSPOT_OWNER_ID=REPLACE_ME

# HubSpot API base URL (EU portal uses api.hubapi.com, same for US)
HUBSPOT_BASE_URL=https://api.hubapi.com

# ─────────────────────────────────────────────
# CALENDAR — CAL.COM
# ─────────────────────────────────────────────

# Cal.com API key
# Create at: app.cal.com/settings/developer/api-keys
CALCOM_API_KEY=cal_live_REPLACE_ME

# Event type ID for the "Discovery Call" event type
# Get by calling: GET https://api.cal.com/v1/event-types?apiKey={CALCOM_API_KEY}
CALCOM_EVENT_TYPE_ID=REPLACE_ME

# Cal.com username (your cal.com/username)
CALCOM_USERNAME=REPLACE_ME

# Cal.com API base URL
CALCOM_BASE_URL=https://api.cal.com/v1

# ─────────────────────────────────────────────
# OBSERVABILITY — LANGFUSE
# ─────────────────────────────────────────────

# Langfuse cloud (free tier, unlimited events)
# Create at: cloud.langfuse.com → Settings → API Keys
LANGFUSE_SECRET_KEY=sk-lf-REPLACE_ME
LANGFUSE_PUBLIC_KEY=pk-lf-REPLACE_ME
LANGFUSE_HOST=https://cloud.langfuse.com

# Project name shown in Langfuse dashboard
LANGFUSE_PROJECT=conversion-engine

# ─────────────────────────────────────────────
# WEBHOOK SERVER — RENDER
# ─────────────────────────────────────────────

# Your Render deployment URL (set after first deploy)
# Format: https://conversion-engine-XXXX.onrender.com
RENDER_URL=https://conversion-engine.onrender.com

# Webhook secret used to verify incoming payloads (any random string)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=REPLACE_WITH_RANDOM_SECRET

# Port for local webhook server development
WEBHOOK_PORT=8000

# ─────────────────────────────────────────────
# ENRICHMENT SOURCES
# ─────────────────────────────────────────────

# Crunchbase (optional — uses ODM Apache 2.0 dataset locally if not set)
CRUNCHBASE_API_KEY=

# SerperDev for job-post scraping fallback (optional)
SERPER_API_KEY=

# ─────────────────────────────────────────────
# SYSTEM CONFIG
# ─────────────────────────────────────────────

# Environment: development | staging | production
APP_ENV=development

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Path to project root (auto-detected if not set)
PROJECT_ROOT=

# Maximum prospects to process per run
MAX_PROSPECTS_PER_RUN=10

# Minimum ICP confidence score to trigger outreach (0.0 – 1.0)
ICP_CONFIDENCE_THRESHOLD=0.6

# AI maturity minimum score to trigger AI-specific pitch angle
AI_MATURITY_PITCH_THRESHOLD=2
